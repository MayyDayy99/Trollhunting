{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/hud/**",
              "guidelines/fx/**",
              "mp-server/public/**",
              "ui_kits/mohas-roham/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Chakra Petch|Space Grotesk|Gelasio|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Chakra Petch, Space Grotesk, Gelasio, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|danger|warn|success|fire|ice|poison|lightning)$/]",
        "message": "<Badge> tone must be one of 'neutral' | 'danger' | 'warn' | 'success' | 'fire' | 'ice' | 'poison' | 'lightning'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|disabled|type|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, disabled, type, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|p2|glass|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'p2' | 'glass' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ChargeMeter'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|show|width|style|key|ref|className|style|children)$/]",
        "message": "<ChargeMeter> doesn't accept that prop. Declared props: value, show, width, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Crosshair'] > JSXAttribute > JSXIdentifier[name!=/^(?:spread|element|size|style|key|ref|className|style|children)$/]",
        "message": "<Crosshair> doesn't accept that prop. Declared props: spread, element, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Crosshair'] > JSXAttribute[name.name='element'] > Literal[value!=/^(?:base|fire|ice|poison|lightning)$/]",
        "message": "<Crosshair> element must be one of 'base' | 'fire' | 'ice' | 'poison' | 'lightning'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ElementMeta'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|key|grad|color|key|ref|className|style|children)$/]",
        "message": "<ElementMeta> doesn't accept that prop. Declared props: id, label, key, grad, color."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|style|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:faint|gold|p1|p2)$/]",
        "message": "<Eyebrow> tone must be one of 'faint' | 'gold' | 'p1' | 'p2'."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlassPanel'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|radius|padding|style|key|ref|className|style|children)$/]",
        "message": "<GlassPanel> doesn't accept that prop. Declared props: children, tone, radius, padding, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlassPanel'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:panel|raised|scrim)$/]",
        "message": "<GlassPanel> tone must be one of 'panel' | 'raised' | 'scrim'."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlassPanel'] > JSXAttribute[name.name='radius'] > Literal[value!=/^(?:md|lg|xl|pill)$/]",
        "message": "<GlassPanel> radius must be one of 'md' | 'lg' | 'xl' | 'pill'."
      },
      {
        "selector": "JSXOpeningElement[name.name='HealthBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|width|height|color|style|key|ref|className|style|children)$/]",
        "message": "<HealthBar> doesn't accept that prop. Declared props: value, label, width, height, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|size|label|background|onClick|style|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: children, tone, size, label, background, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:glass|smash|roar)$/]",
        "message": "<IconButton> tone must be one of 'glass' | 'smash' | 'roar'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PlayerCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|color|hp|you|down|style|key|ref|className|style|children)$/]",
        "message": "<PlayerCard> doesn't accept that prop. Declared props: name, color, hp, you, down, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScorePill'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|align|style|key|ref|className|style|children)$/]",
        "message": "<ScorePill> doesn't accept that prop. Declared props: value, label, align, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ScorePill'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|right|center)$/]",
        "message": "<ScorePill> align must be one of 'left' | 'right' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPip'] > JSXAttribute > JSXIdentifier[name!=/^(?:status|size|label|style|key|ref|className|style|children)$/]",
        "message": "<StatusPip> doesn't accept that prop. Declared props: status, size, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Toast'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|show|style|key|ref|className|style|children)$/]",
        "message": "<Toast> doesn't accept that prop. Declared props: children, show, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='WaveBanner'] > JSXAttribute > JSXIdentifier[name!=/^(?:wave|trollsLeft|style|key|ref|className|style|children)$/]",
        "message": "<WaveBanner> doesn't accept that prop. Declared props: wave, trollsLeft, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
